{
  "name": "cloudfront-update-distribution",
  "version": "1.0.0",
  "description": "Updates an AWS cloudfront distribution",
  "main": "index.js",
  "scripts": {
    "build": "ncc build src/index.ts -o dist && ncc build src/cleanup.ts -o dist/cleanup",
    "lint": "eslint --fix 'src/**/*.ts'"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chaitanyapotti/cloudfront-update-distribution.git"
  },
  "keywords": [
    "AWS",
    "Cloudfront",
    "Github",
    "Actions",
    "javascript"
  ],
  "author": "Chaitanya Potti",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/chaitanyapotti/cloudfront-update-distribution/issues"
  },
  "homepage": "https://github.com/chaitanyapotti/cloudfront-update-distribution#readme",
  "dependencies": {
    "@actions/core": "^3.0.0",
    "@aws-sdk/client-cloudfront": "^3.1012.0",
    "deepmerge": "^4.3.1"
  },
  "devDependencies": {
    "@vercel/ncc": "^0.38.4",
    "@toruslabs/eslint-config-node": "^5.0.1",
    "@types/node": "^25",
    "eslint": "^9.21.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20.x"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "*.{js,ts,css,json,md}": [
      "prettier --write 'src/*'"
    ],
    "*.{js,ts}": [
      "npm run lint --"
    ]
  }
}
