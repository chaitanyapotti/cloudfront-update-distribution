{
  "name": "cloudfront-update-distribution",
  "version": "1.0.0",
  "description": "Updates an AWS cloudfront distribution",
  "main": "index.js",
  "scripts": {
    "build": "ncc build src/index.ts -o dist && ncc build src/cleanup.ts -o dist/cleanup",
    "lint": "eslint --fix 'src/**/*.ts'"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chaitanyapotti/cloudfront-update-distribution.git"
  },
  "keywords": [
    "AWS",
    "Cloudfront",
    "Github",
    "Actions",
    "javascript"
  ],
  "author": "Chaitanya Potti",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/chaitanyapotti/cloudfront-update-distribution/issues"
  },
  "homepage": "https://github.com/chaitanyapotti/cloudfront-update-distribution#readme",
  "dependencies": {
    "@actions/core": "^1.11.1",
    "@aws-sdk/client-cloudfront": "^3.758.0",
    "deepmerge": "^4.3.1"
  },
  "devDependencies": {
    "@vercel/ncc": "^0.38.3",
    "@toruslabs/eslint-config-node": "^4.1.0",
    "@types/node": "^22",
    "eslint": "^9.21.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.4.3",
    "prettier": "^3.5.2",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=20.x"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "*.{js,ts,css,json,md}": [
      "prettier --write 'src/*'"
    ],
    "*.{js,ts}": [
      "npm run lint --"
    ]
  }
}
